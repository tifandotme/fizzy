#!/usr/bin/env bash

# A sample pre-deploy hook
#
# Sets up the deployment server with necessary permissions and directories
#
# These environment variables are available:
# KAMAL_RECORDED_AT
# KAMAL_PERFORMER
# KAMAL_VERSION
# KAMAL_HOSTS
# KAMAL_COMMAND
# KAMAL_SUBCOMMAND
# KAMAL_ROLES (if set)
# KAMAL_DESTINATION (if set)

echo "Setting up deployment environment..."

# Only run setup for production deployments
if [ "$KAMAL_COMMAND" = "rollback" ] || [ "$KAMAL_DESTINATION" != "production" ]; then
  exit 0
fi

set -e

# Add deploy user to docker group if not already
if ! groups | grep -q docker; then
  echo "Adding user to docker group..."
  sudo usermod -aG docker "$USER"
  sudo systemctl restart docker || sudo service docker restart || true
fi

# Create and set permissions for storage directory
echo "Creating fizzy-storage directory..."
mkdir -p "$HOME/fizzy-storage"
chmod 777 "$HOME/fizzy-storage" # have to be 777

# Create GCP-related directories
echo "Creating GCP directories..."
mkdir -p "$HOME/.gcp"
mkdir -p "$HOME/.logs"
chmod 700 "$HOME/.gcp"

echo "Deployment environment setup complete"
exit 0
